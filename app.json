{
  "expo": {
    "name": "DRAPE",
    "slug": "drape",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "drape",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drapeapp.app",
      "infoPlist": {
        "NSCameraUsageDescription": "DRAPE needs the camera to capture your likeness and clothing.",
        "NSPhotoLibraryUsageDescription": "DRAPE needs photo access to import likeness and clothing images.",
        "NSPhotoLibraryAddUsageDescription": "DRAPE saves generated looks to your photo library."
      }
    },
    "android": {
      "package": "com.drapeapp.app",
      "adaptiveIcon": {
        "backgroundColor": "#ECDDBE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ECDDBE"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow DRAPE to access your photos for likeness and wardrobe.",
          "cameraPermission": "Allow DRAPE to use the camera for likeness and wardrobe."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DRAPE to use the camera for likeness and wardrobe."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow DRAPE to save generated looks.",
          "savePhotosPermission": "Allow DRAPE to save generated looks.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-font",
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
